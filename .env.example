# ============================================================
#  NET-1 — Environment Variables
#  Copy to .env and fill in your values.
#  Place at: net-1/.env
#  NEVER commit .env to git.
# ============================================================

# Django core
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Security headers — set True only if serving over HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# Database — matches postgres service name in podman-compose
DB_NAME=net1db
DB_USER=net1user
DB_PASSWORD=change-me-strong-db-password
DB_HOST=postgres
DB_PORT=5432

# Valkey — matches valkey service name in podman-compose
VALKEY_HOST=valkey
VALKEY_PORT=6379

# Ollama — matches ollama service name in podman-compose
OLLAMA_HOST=http://ollama:11434
